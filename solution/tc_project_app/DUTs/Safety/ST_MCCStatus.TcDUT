<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <DUT Name="ST_MCCStatus" Id="{00ac038e-aa81-4175-9c09-5cd4fbc6f3e8}">
    <Declaration><![CDATA[(*
Status information for a cabinet, will not change from cabinet to cabinet,
input/output represents bits 00-15 in safety controller.
*)
TYPE ST_MCCStatus :
STRUCT
    refIn: REFERENCE TO ST_MCCStatusIn;
    refOut: REFERENCE TO ST_MCCStatusOut;
END_STRUCT
END_TYPE
]]></Declaration>
  </DUT>
</TcPlcObject>