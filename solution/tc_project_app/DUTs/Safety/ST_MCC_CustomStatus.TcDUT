<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <DUT Name="ST_MCC_CustomStatus" Id="{6e0330ba-8186-0b3e-1827-26396cd792da}">
    <Declaration><![CDATA[(*
Status information for a cabinet, can be customized depending on cabinet,
input/output represents bits 16-31 in safety controller.
*)
TYPE ST_MCC_CustomStatus :
STRUCT
    In: ST_MCC_CustomStatusIn;
    Out: ST_MCC_CustomStatusOut;
END_STRUCT
END_TYPE
]]></Declaration>
  </DUT>
</TcPlcObject>